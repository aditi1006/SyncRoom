# ---- Server (runtime) ----
PORT=3001
# Origin allowed by CORS when the client is hosted separately:
CLIENT_ORIGIN=http://localhost:5173

# ---- Client (build-time, Vite) ----
# Socket server URL when NOT served from the same origin:
# VITE_SERVER_URL=https://ws.example.com
# TURN relay for strict-NAT peers (strongly recommended in production):
# VITE_TURN_URL=turn:turn.example.com:3478
# VITE_TURN_USERNAME=syncroom
# VITE_TURN_CREDENTIAL=change-me
