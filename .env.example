# ============================================================
# SyncRoom environment reference
# Copy values into your host's dashboard, do NOT commit a .env.
# ============================================================

# ---- Server (runtime, set on Render / Fly / your VPS) ----

# Listen port. Render injects PORT automatically; leave unset there.
PORT=3001

# Production mode. Set this on every deployment (Render/Fly/VPS).
NODE_ENV=production

# Comma-separated origin allow-list for CORS/WebSocket handshakes.
# Exact origins and wildcard subdomains (https://*.vercel.app) are supported.
# Production example:
#   CLIENT_ORIGIN=https://syncroom.vercel.app,https://*.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# ---- Server: scalability knobs (all optional, sane defaults) ----

# Serve the built SPA from this process? Set false in split deployments where
# a CDN/static host (Vercel, Render Static, Cloudflare, Netlify) serves the
# frontend, so this box handles signaling only.
#   SERVE_CLIENT=false

# Overload protection: max concurrent WebSocket connections. New handshakes
# past this are rejected at the handshake (existing users unaffected).
#   MAX_CONNECTIONS=150

# Connection-burst smoothing (handshakes/sec admitted before staggering, and
# the max stagger delay in ms). Spreads join spikes so CPU doesn't spike.
#   CONNECTION_BURST_PER_SEC=20
#   CONNECTION_MAX_STAGGER_MS=500

# Heartbeat: ping every PING_INTERVAL_MS, drop the socket if no pong within
# PING_TIMEOUT_MS. Evicts abandoned tabs so they don't leak memory.
#   PING_INTERVAL_MS=30000
#   PING_TIMEOUT_MS=60000

# Max concurrent Google-Drive proxy streams (the one path where bytes flow
# through the server; media proper is P2P). Excess requests get a 503.
#   MAX_DRIVE_STREAMS=8

# Self-restart if RSS crosses this many MB (0 = disabled). Render free = 512 MB.
#   MEMORY_LIMIT_MB=450

# ---- Client (BUILD-time, set in the Vercel dashboard) ----
# Vite inlines VITE_* variables at build time; changing them requires a
# redeploy, not a restart.

# The Socket.IO server URL (https://, the socket upgrades to wss:// itself).
# Required for split deployments; omit when the server serves the SPA.
#   VITE_SERVER_URL=https://syncroom-server.onrender.com

# TURN relay for strict-NAT peers (~10-15% of connections fail without one).
# Free option: https://www.metered.ca/tools/openrelay/ (Open Relay).
#   VITE_TURN_URL=turn:standard.relay.metered.ca:443?transport=tcp
#   VITE_TURN_USERNAME=your-username
#   VITE_TURN_CREDENTIAL=your-credential
